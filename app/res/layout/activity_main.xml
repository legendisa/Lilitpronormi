<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🦇 LILITH"
        android:textSize="24sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="49 ÖZELLİK | SES | ROOT | EKRAN | SMS | BINARY"
        android:textSize="10sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0f3460"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/consoleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:text="Lilith hazır...\n"/>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/inputEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Komut yaz..."
            android:textColor="#ffffff"
            android:textColorHint="#888888"
            android:background="#16213e"
            android:padding="12dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gönder"
            android:backgroundTint="#e94560"/>

        <Button
            android:id="@+id/voiceButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎤"
            android:backgroundTint="#533483"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/accessibilityButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔓 Erişilebilirlik İzni Ver"
        android:backgroundTint="#f39c12"
        android:textSize="12sp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text='Örnek: "merhaba" | "root ls" | "sms 05XX mesaj" | "ekranda ne var" | "beni tanı"'
        android:textSize="8sp"
        android:textColor="#555555"
        android:gravity="center"
        android:layout_marginTop="8dp"/>

</LinearLayout>
